# --- Server configuration ---
# Port the HTTP server listens on
PORT=3001
# Node environment: development | production | test
NODE_ENV=development

# Comma separated list of allowed origins for CORS (the client dev server).
CORS_ORIGIN=http://localhost:5173

# --- Data layer ---
# Absolute or relative path (relative to the server root) to the directory that
# contains the `database.json` files and the `images/` + `icons/` sub-folders.
# If left empty, the server defaults to `./data`. When no `database.json` is
# present there, it falls back to `database.example.json`. When `./data/images`
# is missing or empty, `about.images` is returned empty and the client hides the
# photo slider.
DATA_DIR=./data

# --- Captcha (bot protection for the contact form) ---
# Provider: none | recaptcha | hcaptcha
# `none` = development mode, token is not verified against a provider.
CAPTCHA_PROVIDER=none
CAPTCHA_SECRET=

# --- E-Mail service (SMTP) ---
# When SMTP_HOST is empty the e-mail service runs in DRY-RUN mode and only logs
# the message instead of sending it (safe for local development).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Recipient of the contact form messages
MAIL_TO=den.kim2207@gmail.com
# From-address used by the transporter
MAIL_FROM=no-reply@denis-kim.dev
